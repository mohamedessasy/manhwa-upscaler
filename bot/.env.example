# ===== Discord =====
# مهم: ولّد توكن جديد — التوكنات القديمة في bot 3 مكشوفة ويجب إلغاؤها
DISCORD_TOKEN=

# ===== Cloudflare R2 =====
# من لوحة Cloudflare: R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=manhwa-upscale

# ===== RunPod Serverless =====
# من runpod.io: Settings > API Keys + Serverless endpoint id
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# ===== الإخراج (متطلبات الموقع) =====
OUT_WIDTH=800
JPEG_QUALITY=85
LINK_EXPIRE_HOURS=168

# ===== حدود =====
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_MINUTES=30
